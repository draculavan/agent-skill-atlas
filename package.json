{
  "name": "agent-skill-atlas",
  "version": "0.1.0",
  "description": "A local-first visual atlas for your AI agent skills.",
  "type": "module",
  "bin": {
    "agent-skill-atlas": "./bin/agent-skill-atlas.js"
  },
  "files": [
    "bin",
    "src",
    "public",
    "examples",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
